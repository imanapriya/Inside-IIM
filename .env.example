# ==============================================================================
# Vanguard AI - Environment Configuration Example
# Copy this file to .env.local and populate with your API credentials.
# ==============================================================================

# OpenAI API Key (Required for live runs using GPT-4o-mini)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API Key (Alternative for live runs using Gemini 1.5 Flash)
GEMINI_API_KEY=your_gemini_api_key_here

# Tavily API Key (Required for live web search functionality)
TAVILY_API_KEY=your_tavily_api_key_here
